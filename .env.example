# Copy to .env for local overrides (optional — docker-compose has sensible defaults).
# Same variable names are used in AWS/EKS via Secrets Manager or Helm values.

APP_ENV=local
LOG_LEVEL=INFO
AUTH_MODE=disabled

DATABASE_URL=postgresql://opsdeck:opsdeck@postgres:5432/opsdeck
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ENCRYPTION_KEY=opsdeck-dev-key-change-in-production-32b=

STORAGE_TYPE=local
# S3_BUCKET=
# S3_REGION=

PROMETHEUS_ENABLED=true
PROMETHEUS_FILE_SD_DIR=/app/prometheus/file_sd
PROMETHEUS_INTERNAL_URL=http://prometheus:9090
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3001
GRAFANA_EMBED_URL=http://localhost:3001/d/opsdeck-overview/opsdeck-overview?orgId=1&theme=dark&kiosk
